# Environment (dev or prod)
API_ENV=dev
PORT=8080

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Google
GOOGLE_PLACES_API_KEY=your-google-places-key
GOOGLE_GEMINI_API_KEY=your-google-gemini-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Clerk Authentication
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_AUDIENCE=menuto-backend
# CLERK_JWKS_URL=https://your-clerk-instance/.well-known/jwks.json  # prod only

# CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:8080,exp://*
